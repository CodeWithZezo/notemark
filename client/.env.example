# Find these in: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key (safe to expose in the browser;
# Row Level Security enforces data isolation per user)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
